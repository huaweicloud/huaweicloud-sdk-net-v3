name: .NET Download

on:
  workflow_dispatch:
jobs:
  download:
    runs-on: ubuntu-22.04
    steps:
    - uses: actions/checkout@v4
    - name: Setup .NET
      uses: actions/setup-dotnet@v4
    - name: Download
      run: |
        services=$(ls Services)
        version=$(cat VERSION)
        dotnet new console -n MyDotNetApp
        cd MyDotNetApp || exit 1
        for service in "$services"; do
          dotnet add package "HuaweiCloud.SDK.${service}" --version "$version"
        done
        cat MyDotNetApp.csproj
      shell: bash
